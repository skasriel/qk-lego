// LDraw color palette (subset of most common colors)
const LDRAW_COLORS = {
  0: '#000000',   // Black
  1: '#0055BF',   // Blue
  2: '#237841',   // Green
  3: '#C91A09',   // Red
  4: '#F2CD37',   // Yellow
  5: '#FFFFFF',   // White
  6: '#FF8000',   // Orange
  7: '#E4ADC8',   // Pink
  8: '#958A73',   // Tan
  9: '#FC0000',   // Bright Red
  10: '#79922B',  // Bright Green
  11: '#B35608',  // Brown
  12: '#4C61DB',  // Bright Blue
  13: '#F8BB3D',  // Bright Yellow
  14: '#E4ADC8',  // Light Pink
  15: '#FFFFFF',  // White
  // ... more colors can be added
  71: '#FFFFFF',   // Light Bluish Gray
  72: '#6B5A5A',  // Dark Bluish Gray
  92: '#C91A09',  // Red (alternate)
};

// Parse MPD/LDR file recursively
function parseMPD(content, basePath = '', depth = 0, maxDepth = 10, parentMatrix = null) {
  if (depth > maxDepth) return [];
  
  const bricks = [];
  const lines = content.split('\n');
  
  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed || trimmed.startsWith('0')) continue;
    
    const parts = trimmed.split(/\s+/);
    if (parts[0] !== '1' || parts.length < 15) continue;
    
    const colorCode = parseInt(parts[1]);
    const x = parseFloat(parts[2]);
    const y = parseFloat(parts[3]);
    const z = parseFloat(parts[4]);
    // Extract 3x3 rotation matrix
    const a = parseFloat(parts[5]), b = parseFloat(parts[6]), c = parseFloat(parts[7]);
    const d = parseFloat(parts[8]), e = parseFloat(parts[9]), f = parseFloat(parts[10]);
    const g = parseFloat(parts[11]), h = parseFloat(parts[12]), i = parseFloat(parts[13]);
    const filename = parts.slice(14).join(' ');
    
    // Create transformation matrix for this part
    const transform = {
      x: x / 2.5,
      y: -y / 2.5,
      z: z / 2.5,
      matrix: [a, b, c, d, e, f, g, h, i]
    };
    
    // If we have a parent transform, combine them
    if (parentMatrix) {
      // Apply parent transformation to this position
      const px = transform.x, py = transform.y, pz = transform.z;
      transform.x = parentMatrix.m[0] * px + parentMatrix.m[1] * py + parentMatrix.m[2] * pz + parentMatrix.x;
      transform.y = parentMatrix.m[3] * px + parentMatrix.m[4] * py + parentMatrix.m[5] * pz + parentMatrix.y;
      transform.z = parentMatrix.m[6] * px + parentMatrix.m[7] * py + parentMatrix.m[8] * pz + parentMatrix.z;
      // Combine rotation matrices (simplified - just use parent for now)
      transform.matrix = parentMatrix.m;
    }
    
    // Check if this is a sub-model or a part
    const isSubmodel = !filename.endsWith('.dat') || filename.includes(' - ');
    
    if (isSubmodel && depth < maxDepth) {
      // Recursively load sub-model
      try {
        const subPath = require('path').join(
          require('path').dirname(basePath),
          filename
        );
        if (require('fs').existsSync(subPath)) {
          const subContent = require('fs').readFileSync(subPath, 'utf8');
          const subBricks = parseMPD(subContent, subPath, depth + 1, maxDepth, transform);
          bricks.push(...subBricks);
        }
      } catch (e) {
        // Skip if sub-model not found
      }
    } else {
      // Direct part
      const color = LDRAW_COLORS[colorCode] || '#808080';
      bricks.push({
        uuid: Math.random().toString(36).substr(2, 9),
        position: { x: transform.x, y: transform.y, z: transform.z },
        color: color,
        colorType: 'solid',
        brickID: filename.replace('.dat', ''),
        angle: 0,
        brickType: 'BASIC_BRICK',
        width: 2,
        height: 3,
        depth: 2,
      });
    }
    }
  }
  
  return bricks;
}

module.exports = { parseMPD };