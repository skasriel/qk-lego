{
  "$schema": "https://schema.railpack.com/railpack.schema.json",
  "packages": {
    "node": "22"
  },
  "steps": {
    "install": {
      "commands": [
        "npm install",
        "cd client && npm install",
        "cd ../server && npm install"
      ]
    },
    "build": {
      "commands": [
        "cd client && npm run build"
      ]
    }
  },
  "deploy": {
    "startCommand": "cd server && node server.js"
  }
}
